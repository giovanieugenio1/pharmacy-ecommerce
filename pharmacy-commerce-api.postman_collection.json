{
  "info": {
    "name": "Pharmacy Commerce API",
    "description": "E-commerce da farmácia — v6 (COMPLETA): Auth, Home, Banners, Categorias, Marcas, Produtos, Preços, Estoque, Clientes, Carrinho, Pedidos, Busca, Auditoria.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "pharmacy-commerce-api-v6"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('authToken', body.data.token);",
                  "    pm.test('Login realizado com sucesso', () => pm.expect(body.success).to.be.true);",
                  "    pm.test('Token salvo na variável authToken', () => pm.expect(body.data.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@farmacia.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Autentica o administrador e salva automaticamente o token JWT na variável `authToken`."
          }
        },
        {
          "name": "Login (Cliente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('authToken', body.data.token);",
                  "    pm.test('Login realizado com sucesso', () => pm.expect(body.success).to.be.true);",
                  "    pm.test('Token salvo na variável authToken', () => pm.expect(body.data.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@email.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": {
